# Local Runtime Defaults

# Determines environment-specific behaviors (e.g., local profiling, logging behavior)
# Options: development, staging, production
ENVIRONMENT=development

# Controls the verbosity of the structured logger
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Forces the output format of the structured logger
# Options: auto (depends on ENVIRONMENT), console (human readable), json (machine readable)
LOG_FORMAT=console

# (Optional) LangSmith tracing configuration
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=lsv2_...
# LANGCHAIN_PROJECT=bestow-poc

# Live Model Provider Configuration (Explicit Routing)
# Main model for application logic
LLM_MAIN_MODEL=gpt-4o-mini
LLM_MAIN_API_KEY=sk-proj-...
# LLM_MAIN_API_BASE=

# (Stretch Goal) Local SLM for PII Guardrail
# LLM_GUARDRAIL_MODEL=ollama/llama3.1:8b
# Choose your deployment target for the Guardrail API:
#
# 1. Native Mac Host (Recommended for local dev using Metal GPU)
LLM_GUARDRAIL_API_BASE=http://host.docker.internal:11434
#
# 2. In-cluster deployment (e.g., AWS/Azure Staging, or raw K8s testing)
# LLM_GUARDRAIL_API_BASE=http://ollama:11434
#
# 3. Localhost (when running the Python API completely outside Docker)
# LLM_GUARDRAIL_API_BASE=http://localhost:11434
# LLM_GUARDRAIL_API_KEY=local-dev
# LLM_GUARDRAIL_SECRET_KEY=  # Run `make generate-guardrail-key` to generate
